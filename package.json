{
  "name": "@xdd-zone/core",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone Core - Backend API",
  "author": "xidongdong-153",
  "license": "MIT",
  "homepage": "https://github.com/xdd-zone/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xdd-zone/core"
  },
  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": "1.3.5"
  },
  "scripts": {
    "dev": "bun run --filter @xdd-zone/nexus --filter @xdd-zone/console --parallel --elide-lines=0 dev",
    "dev:all": "bun run --filter @xdd-zone/nexus --filter @xdd-zone/console --parallel --elide-lines=0 dev",
    "dev:nexus": "bun run --filter @xdd-zone/nexus --elide-lines=0 dev",
    "dev:console": "bun run --filter @xdd-zone/console --elide-lines=0 dev",
    "build": "bun run --filter '*' build",
    "build:nexus": "bun run --filter @xdd-zone/nexus build",
    "build:console": "bun run --filter @xdd-zone/console build",
    "lint": "bun run lint:nexus && bun run lint:console",
    "lint:nexus": "eslint --no-error-on-unmatched-pattern --config packages/nexus/eslint.config.js packages/nexus/src packages/nexus/scripts",
    "lint:console": "eslint --config packages/console/eslint.config.js packages/console/src",
    "lint:fix": "bun run lint:fix:nexus && bun run lint:fix:console",
    "lint:fix:nexus": "eslint --no-error-on-unmatched-pattern --config packages/nexus/eslint.config.js packages/nexus/src packages/nexus/scripts --fix",
    "lint:fix:console": "eslint --config packages/console/eslint.config.js packages/console/src --fix",
    "format": "prettier --write packages/",
    "format:check": "prettier --check packages/",
    "type-check": "bun run --filter '*' type-check",
    "clean": "rm -rf packages/*/node_modules packages/*/dist",
    "prisma:generate": "bun run --filter @xdd-zone/nexus prisma:generate",
    "prisma:migrate": "bun run --filter @xdd-zone/nexus prisma:migrate",
    "prisma:reset": "bun run --filter @xdd-zone/nexus prisma:reset",
    "prisma:push": "bun run --filter @xdd-zone/nexus prisma:push",
    "seed": "bun run --filter @xdd-zone/nexus seed",
    "db": "bun run scripts/db/local.ts"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
