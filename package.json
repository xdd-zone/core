{
  "name": "@xdd-zone/core",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone Core",
  "author": "xidongdong-153",
  "license": "MIT",
  "homepage": "https://github.com/xdd-zone/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xdd-zone/core"
  },
  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@xdd-zone/nexus --filter=@xdd-zone/console",
    "dev:all": "pnpm run dev",
    "dev:nexus": "turbo run dev --filter=@xdd-zone/nexus",
    "dev:console": "turbo run dev --filter=@xdd-zone/console",
    "build": "turbo run build",
    "build:nexus": "turbo run build --filter=@xdd-zone/nexus",
    "build:console": "turbo run build --filter=@xdd-zone/console",
    "lint": "turbo run lint",
    "lint:nexus": "turbo run lint --filter=@xdd-zone/nexus",
    "lint:console": "turbo run lint --filter=@xdd-zone/console",
    "lint:fix": "turbo run lint:fix",
    "lint:fix:nexus": "turbo run lint:fix --filter=@xdd-zone/nexus",
    "lint:fix:console": "turbo run lint:fix --filter=@xdd-zone/console",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "type-check": "turbo run type-check",
    "type-check:nexus": "turbo run type-check --filter=@xdd-zone/nexus",
    "type-check:console": "turbo run type-check --filter=@xdd-zone/console",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
