{
  "name": "@xdd-zone/momo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone Backend API",
  "author": "xidongdong-153",
  "license": "MIT",
  "homepage": "https://github.com/xdd-zone/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xdd-zone/core",
    "directory": "apps/momo"
  },
  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "keywords": [],
  "turbo": {
    "build": {
      "outputs": [
        "dist/**"
      ]
    }
  },
  "imports": {
    "#momo/bootstrap": "./src/bootstrap/index.ts",
    "#momo/infra/cache": "./src/infra/cache/index.ts",
    "#momo/infra/search": "./src/infra/search/index.ts",
    "#momo/infra/storage": "./src/infra/storage/index.ts",
    "#momo/middleware": "./src/middleware/index.ts",
    "#momo/routes": "./src/routes/index.ts",
    "#momo/*": "./src/*.ts"
  },
  "exports": {
    ".": {
      "development": "./src/app.ts",
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./rpc": {
      "development": "./src/rpc.ts",
      "types": "./dist/rpc.d.ts",
      "import": "./dist/rpc.js",
      "default": "./dist/rpc.js"
    }
  },
  "scripts": {
    "dev": "dotenv -e .env.development -- tsx watch --conditions=development src/index.ts",
    "dev:cs": "dotenv -e .env.code-server -- tsx watch --conditions=development src/index.ts",
    "build": "tsup src/index.ts src/app.ts src/rpc.ts --format esm --dts --out-dir dist",
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "lint:fix": "eslint --no-error-on-unmatched-pattern . --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "test": "dotenv -e .env.test -- vitest run --config vitest.config.ts --passWithNoTests",
    "type-check": "tsc --noEmit",
    "auth:generate": "dotenv -e .env.development -- better-auth generate --config src/modules/auth/auth.generate.ts --output src/infra/db/schema/auth.schema.ts --yes && eslint --fix src/infra/db/schema/auth.schema.ts",
    "seed:owner": "dotenv -e .env.development -- tsx --conditions=development src/scripts/seed-owner.ts",
    "storage:test": "dotenv -e .env.development -- tsx --conditions=development src/scripts/test-storage.ts",
    "local:up": "docker compose -f compose.yaml up -d",
    "local:down": "docker compose -f compose.yaml down",
    "db:generate": "dotenv -e .env.development -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.development -- drizzle-kit migrate",
    "db:check": "dotenv -e .env.development -- drizzle-kit check",
    "db:studio": "dotenv -e .env.development -- drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/zod-validator": "catalog:",
    "@xdd-zone/contracts": "workspace:*",
    "better-auth": "catalog:",
    "cos-nodejs-sdk-v5": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "meilisearch": "catalog:",
    "pino": "catalog:",
    "postgres": "catalog:",
    "redis": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/cli": "catalog:",
    "@types/node": "catalog:",
    "@xdd-zone/eslint-config": "workspace:*",
    "dotenv-cli": "catalog:",
    "drizzle-kit": "catalog:",
    "pino-pretty": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
