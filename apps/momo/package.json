{
  "name": "@xdd-zone/momo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone Backend API",
  "author": "xidongdong-153",
  "license": "MIT",
  "homepage": "https://github.com/xdd-zone/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xdd-zone/core",
    "directory": "apps/momo"
  },
  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "keywords": [],
  "turbo": {
    "build": {
      "outputs": [
        "dist/**"
      ]
    }
  },
  "imports": {
    "#momo/routes": "./src/routes/index.ts",
    "#momo/*": "./src/*.ts"
  },
  "exports": {
    ".": {
      "development": "./src/app.ts",
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./rpc": {
      "development": "./src/rpc.ts",
      "types": "./dist/rpc.d.ts",
      "import": "./dist/rpc.js",
      "default": "./dist/rpc.js"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development APP_ENV=development PORT=7788 CORS_ORIGINS=http://localhost:2333,http://127.0.0.1:2333 DATABASE_URL=postgres://momo:momo@localhost:55432/momo tsx watch --conditions=development src/index.ts",
    "build": "tsup src/index.ts src/app.ts src/rpc.ts --format esm --dts --out-dir dist",
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "lint:fix": "eslint --no-error-on-unmatched-pattern . --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "test": "APP_ENV=test PORT=7788 CORS_ORIGINS=http://localhost:2333,http://127.0.0.1:2333 DATABASE_URL=postgres://momo:momo@localhost:55432/momo vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "db:up": "docker compose -f compose.yaml up -d",
    "db:down": "docker compose -f compose.yaml down",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgres://momo:momo@localhost:55432/momo} drizzle-kit generate",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgres://momo:momo@localhost:55432/momo} drizzle-kit migrate",
    "db:check": "DATABASE_URL=${DATABASE_URL:-postgres://momo:momo@localhost:55432/momo} drizzle-kit check",
    "db:studio": "DATABASE_URL=${DATABASE_URL:-postgres://momo:momo@localhost:55432/momo} drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/zod-validator": "catalog:",
    "@xdd-zone/contracts": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "postgres": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@xdd-zone/eslint-config": "workspace:*",
    "drizzle-kit": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
