# -- App --
APP_ENV=development
PORT=7788
LOG_LEVEL=info
LOG_SQL=false
MOMO_PUBLIC_BASE_URL=http://localhost:7788
CORS_ORIGINS=http://localhost:2333,http://127.0.0.1:2333,http://localhost:4399,http://127.0.0.1:4399

# -- Database --
DATABASE_URL=postgres://momo:momo@localhost:55432/momo

# -- Auth --
BETTER_AUTH_SECRET=replace-with-at-least-32-random-chars
BETTER_AUTH_URL=http://localhost:7788
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# -- Cache --
CACHE_PROVIDER=memory
CACHE_URL=
CACHE_KEY_PREFIX=momo
CACHE_DEFAULT_TTL_SECONDS=300

# -- Search --
SEARCH_PROVIDER=none
MEILI_HOST=http://localhost:57700
MEILI_API_KEY=momo-meilisearch-development-master-key
MEILI_INDEX_PREFIX=momo

# -- LLM --
LLM_SECRET_KEY=replace-with-32-byte-base64-key

# -- Seed --
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-owner-password
OWNER_DISPLAY_NAME=Owner

# -- Storage --
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-shanghai
COS_PUBLIC_BASE_URL=
COS_KEY_PREFIX=media
COS_SIGNED_URL_EXPIRES=600
