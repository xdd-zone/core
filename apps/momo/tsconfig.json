{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "rootDir": ".",
    "customConditions": ["development"],
    "paths": {
      "#momo/bootstrap": ["./src/bootstrap/index.ts"],
      "#momo/middleware": ["./src/middleware/index.ts"],
      "#momo/routes": ["./src/routes/index.ts"],
      "#momo/*": ["./src/*"]
    },
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "*.generated.ts"]
}
