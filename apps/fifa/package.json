{
  "name": "@xdd-zone/fifa",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone Fifa",
  "author": "xidongdong-153",
  "license": "MIT",
  "homepage": "https://github.com/xdd-zone/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xdd-zone/core",
    "directory": "apps/fifa"
  },
  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "keywords": [],
  "imports": {
    "#fifa/*": "./src/*.ts"
  },
  "turbo": {
    "build": {
      "outputs": [
        "dist/**"
      ]
    }
  },
  "scripts": {
    "dev": "dotenv -e .env.development -- vite",
    "build": "pnpm run type-check && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "test": "dotenv -e .env.test -- vitest run --config vitest.config.ts --passWithNoTests",
    "type-check": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "catalog:",
    "@codemirror/language": "catalog:",
    "@codemirror/view": "catalog:",
    "@lezer/highlight": "catalog:",
    "@shikijs/langs": "catalog:shiki",
    "@shikijs/transformers": "catalog:shiki",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@uiw/react-codemirror": "catalog:",
    "@xdd-zone/catppuccin-theme": "workspace:*",
    "@xdd-zone/contracts": "workspace:*",
    "antd": "catalog:",
    "clsx": "catalog:",
    "dayjs": "catalog:",
    "hono": "catalog:",
    "i18next": "catalog:",
    "lucide-react": "catalog:",
    "markdown-to-jsx": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-i18next": "catalog:",
    "react-icons": "catalog:",
    "react-image-crop": "catalog:",
    "react-use": "catalog:",
    "shiki": "catalog:shiki",
    "styled-components": "catalog:",
    "tailwindcss": "catalog:",
    "vite": "catalog:vite",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tanstack/history": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:vite",
    "@xdd-zone/eslint-config": "workspace:*",
    "@xdd-zone/momo": "workspace:*",
    "dotenv-cli": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
