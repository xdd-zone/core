{
  "name": "@xdd-zone/nexus",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone Backend API",
  "author": "xidongdong-153",
  "license": "MIT",
  "homepage": "https://github.com/xdd-zone/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xdd-zone/core",
    "directory": "apps/nexus"
  },
  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "keywords": [],
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "import": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "lint": "eslint --no-error-on-unmatched-pattern src",
    "lint:fix": "eslint --no-error-on-unmatched-pattern src --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@xdd-zone/contracts": "workspace:*",
    "@hono/node-server": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@xdd-zone/eslint-config": "workspace:*",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:",
    "typescript": "catalog:"
  }
}
