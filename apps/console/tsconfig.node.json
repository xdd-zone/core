{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "incremental": true,
    "moduleDetection": "force",
    "paths": {
      "@console/*": ["./src/*"]
    },
    "allowImportingTsExtensions": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["vite.config.ts"]
}
