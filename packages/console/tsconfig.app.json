{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "moduleDetection": "force",
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@console/*": ["src/*"],
      "@nexus/*": ["../nexus/src/*"],
      "@xdd-zone/nexus/eden": ["../nexus/src/public/eden.ts"],
      "@xdd-zone/nexus/auth-types": ["../nexus/src/public/auth-types.ts"],
      "@xdd-zone/nexus/category-types": ["../nexus/src/public/category-types.ts"],
      "@xdd-zone/nexus/comment-types": ["../nexus/src/public/comment-types.ts"],
      "@xdd-zone/nexus/media-types": ["../nexus/src/public/media-types.ts"],
      "@xdd-zone/nexus/post-types": ["../nexus/src/public/post-types.ts"],
      "@xdd-zone/nexus/user-types": ["../nexus/src/public/user-types.ts"],
      "@xdd-zone/nexus/site-config-types": ["../nexus/src/public/site-config-types.ts"],
      "@xdd-zone/nexus/permissions": ["../nexus/src/public/permissions.ts"],
      "@xdd-zone/nexus/rbac-types": ["../nexus/src/public/rbac-types.ts"]
    },
    "allowImportingTsExtensions": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src", "src/viteEnv.d.ts"]
}
