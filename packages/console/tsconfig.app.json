{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "moduleDetection": "force",
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@console/*": ["src/*"],
      "@nexus/*": ["../nexus/src/*"],
      "@xdd-zone/nexus/eden": ["../nexus/src/public/eden.ts"],
      "@xdd-zone/nexus/auth-types": ["../nexus/src/public/auth-types.ts"]
    },
    "allowImportingTsExtensions": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src", "src/viteEnv.d.ts"]
}
