    "antd": "^6.3.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "driver.js": "^1.4.0",
    "i18next": "^25.10.3",
    "lucide-react": "^0.547.0",
    "markdown-to-jsx": "^8.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.0",
    "react-icons": "^5.5.0",
    "react-image-crop": "^11.0.10",
