  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "keywords": [],
  "engines": {
    "bun": "1.3.5"
  },
  "scripts": {
    "dev": "vite",
    "build": "bun run type-check && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "type-check": "bun --bun tsc -p tsconfig.app.json --noEmit && bun --bun tsc -p tsconfig.node.json --noEmit"
  },
