{
  "name": "@xdd-zone/contracts",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone shared API contracts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "lint": "eslint --no-error-on-unmatched-pattern src",
    "lint:fix": "eslint --no-error-on-unmatched-pattern src --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@xdd-zone/eslint-config": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
