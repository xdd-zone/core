{
  "name": "@xdd-zone/catppuccin-theme",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone shared Catppuccin theme",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "turbo": {
    "build": {
      "outputs": [
        "dist/**"
      ]
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./palette": {
      "development": "./src/palette.ts",
      "types": "./dist/palette.d.ts",
      "import": "./dist/palette.js",
      "default": "./dist/palette.js"
    },
    "./color": {
      "development": "./src/color.ts",
      "types": "./dist/color.d.ts",
      "import": "./dist/color.js",
      "default": "./dist/color.js"
    },
    "./antd": {
      "development": "./src/antd.ts",
      "types": "./dist/antd.d.ts",
      "import": "./dist/antd.js",
      "default": "./dist/antd.js"
    },
    "./styles/core.css": "./styles/core.css",
    "./styles/console.css": "./styles/console.css",
    "./styles/bobo.css": "./styles/bobo.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/palette.ts src/color.ts src/antd.ts --format esm --dts --out-dir dist",
    "lint": "eslint --no-error-on-unmatched-pattern src",
    "lint:fix": "eslint --no-error-on-unmatched-pattern src --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "antd": "catalog:"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": true
    }
  },
  "devDependencies": {
    "@xdd-zone/eslint-config": "workspace:*",
    "antd": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
