{
  "name": "@xdd-zone/eslint-config",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone shared ESLint configuration",
  "exports": {
    ".": "./index.js",
    "./prettier": "./prettier.config.js"
  },
  "main": "index.js",
  "files": [
    "index.js",
    "prettier.config.js"
  ],
  "scripts": {
    "lint": "eslint --no-error-on-unmatched-pattern .",
    "lint:fix": "eslint --no-error-on-unmatched-pattern . --fix",
    "format": "prettier --config prettier.config.js --write .",
    "format:check": "prettier --config prettier.config.js --check .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@antfu/eslint-config": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-format": "catalog:",
    "prettier": "catalog:"
  }
}
