# 环境变量配置说明。
# 本地开发时复制为 packages/nexus/.env 后再改值。
# Bun 会根据 NODE_ENV 自动加载对应的 .env 文件：
# - 开发环境：.env + .env.development
# - 生产环境：.env + .env.production

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Better Auth 配置
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:7788

# GitHub OAuth 配置
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# 媒体文件存储配置
# local：文件写入 packages/nexus/storage/media
# cos：文件写入腾讯云 COS，读取仍走 /api/media/:id/file
STORAGE_PROVIDER=local

# STORAGE_PROVIDER=cos 时填写下面这些值。
# 不使用 COS 时保持为空即可。
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PUBLIC_BASE_URL=
