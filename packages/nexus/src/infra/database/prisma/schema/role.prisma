/**
 * 角色模型
 *
 * 作为固定系统角色容器使用。
 */
model Role {
  /// 角色 ID
  id          String   @id @default(cuid())

  /// 角色名称（固定为 superAdmin / admin / user）
  name        String   @unique

  /// 角色显示名称
  displayName String?

  /// 角色描述
  description String?

  /// 是否为系统内置角色
  isSystem    Boolean  @default(false)

  /// 角色权限关联
  permissions RolePermission[]

  /// 用户角色关联
  userRoles   UserRole[]

  /// 创建时间
  createdAt   DateTime @default(now()) @map("created_at")

  /// 更新时间
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("roles")
}
