{
  "name": "@xdd-zone/nexus",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "XDD Zone Backend API",
  "author": "xidongdong-153",
  "license": "MIT",
  "homepage": "https://github.com/xdd-zone/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xdd-zone/core",
    "directory": "packages/nexus"
  },
  "bugs": {
    "url": "https://github.com/xdd-zone/core/issues"
  },
  "keywords": [],
  "exports": {
    "./eden": {
      "types": "./src/public/eden.ts",
      "import": "./src/public/eden.ts",
      "default": "./src/public/eden.ts"
    },
    "./public": {
      "types": "./src/public/index.ts",
      "import": "./src/public/index.ts",
      "default": "./src/public/index.ts"
    },
    "./auth-types": {
      "types": "./src/public/auth-types.ts",
      "import": "./src/public/auth-types.ts",
      "default": "./src/public/auth-types.ts"
    },
    "./user-types": {
      "types": "./src/public/user-types.ts",
      "import": "./src/public/user-types.ts",
      "default": "./src/public/user-types.ts"
    },
    "./comment-types": {
      "types": "./src/public/comment-types.ts",
      "import": "./src/public/comment-types.ts",
      "default": "./src/public/comment-types.ts"
    },
    "./media-types": {
      "types": "./src/public/media-types.ts",
      "import": "./src/public/media-types.ts",
      "default": "./src/public/media-types.ts"
    },
    "./page-types": {
      "types": "./src/public/page-types.ts",
      "import": "./src/public/page-types.ts",
      "default": "./src/public/page-types.ts"
    },
    "./post-types": {
      "types": "./src/public/post-types.ts",
      "import": "./src/public/post-types.ts",
      "default": "./src/public/post-types.ts"
    },
    "./site-config-types": {
      "types": "./src/public/site-config-types.ts",
      "import": "./src/public/site-config-types.ts",
      "default": "./src/public/site-config-types.ts"
    },
    "./permissions": {
      "types": "./src/public/permissions.ts",
      "import": "./src/public/permissions.ts",
      "default": "./src/public/permissions.ts"
    },
    "./rbac-types": {
      "types": "./src/public/rbac-types.ts",
      "import": "./src/public/rbac-types.ts",
      "default": "./src/public/rbac-types.ts"
    }
  },
  "engines": {
    "bun": "1.3.5"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test src/eden/eden-smoke.test.ts src/eden/openapi-smoke.test.ts",
    "seed": "bun run src/infra/database/prisma/seed/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:push:reset": "prisma db push --force-reset",
    "prisma:reset": "prisma db push --force-reset",
    "type-check": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "better-auth": "^1.5.6",
    "dotenv": "^17.4.0",
    "elysia": "^1.4.28",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@xdd-zone/eslint-config": "workspace:*",
    "bun-types": "^1.3.5",
    "prisma": "^7.6.0",
    "typescript": "^5.9.3"
  }
}
