{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "paths": {
      "@nexus/*": ["./src/*"],
      "@nexus-prisma/*": ["./prisma/*"]
    },
    "types": ["bun-types"],
    "outDir": "./dist"
  },
  "include": ["src/**/*", "prisma/seed/**/*"],
  "exclude": ["node_modules", "dist", "*.generated.ts"]
}
