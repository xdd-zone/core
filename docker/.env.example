COMPOSE_PROJECT_NAME=xdd-core

APP_BIND_HOST=127.0.0.1
MOMO_HOST_PORT=7788
FIFA_HOST_PORT=2333
BOBO_HOST_PORT=4399
POSTGRES_HOST_PORT=55432
VALKEY_HOST_PORT=56379
MEILISEARCH_HOST_PORT=57700
LOKI_HOST_PORT=53100

POSTGRES_DB=momo
POSTGRES_USER=momo
POSTGRES_PASSWORD=momo
DATABASE_URL=postgres://momo:momo@postgres:5432/momo

CACHE_PROVIDER=redis
CACHE_URL=redis://valkey:6379
SEARCH_PROVIDER=meilisearch
MEILI_HOST=http://meilisearch:7700
MEILI_API_KEY=momo-meilisearch-development-master-key
LOG_READER_PROVIDER=loki
LOKI_URL=http://loki:3100

MOMO_PUBLIC_BASE_URL=http://localhost:7788
BOBO_PUBLIC_BASE_URL=http://localhost:4399
FIFA_PUBLIC_BASE_URL=http://localhost:2333
CORS_ORIGINS=http://localhost:2333,http://localhost:4399
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
BOBO_REVALIDATE_SECRET=replace-with-a-random-revalidate-secret
LLM_SECRET_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

MOMO_IMAGE=xdd-core-momo:local
FIFA_IMAGE=xdd-core-fifa:local
BOBO_IMAGE=xdd-core-bobo:local
