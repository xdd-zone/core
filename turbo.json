{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "env": [
        "APP_ENV",
        "PORT",
        "DATABASE_URL",
        "VITE_APP_ENV",
        "VITE_MOMO_BASE_URL",
        "BOBO_ALLOWED_DEV_ORIGINS"
      ],
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "APP_ENV",
        "PORT",
        "DATABASE_URL",
        "VITE_APP_ENV",
        "VITE_MOMO_BASE_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "env": [
        "APP_ENV",
        "PORT",
        "DATABASE_URL",
        "VITE_APP_ENV",
        "VITE_MOMO_BASE_URL"
      ],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "env": [
        "APP_ENV",
        "PORT",
        "DATABASE_URL",
        "VITE_APP_ENV",
        "VITE_MOMO_BASE_URL"
      ],
      "outputs": []
    },
    "test": {
      "env": [
        "APP_ENV",
        "PORT",
        "DATABASE_URL",
        "VITE_APP_ENV",
        "VITE_MOMO_BASE_URL"
      ],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
